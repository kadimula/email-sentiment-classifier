# Copy to .env and fill in. Never commit .env (it's gitignored).

# --- Composio (Gmail auth + tooling) -----------------------------------------
# Composio hosts Gmail OAuth, stores/refreshes tokens, and exposes Gmail as tools. Key: https://app.composio.dev (Settings → API Keys).
COMPOSIO_API_KEY=

# --- Trigger.dev -------------------------------------------------------------
# Your project ref from the trigger.dev dashboard (Project settings); used by trigger.config.ts.
TRIGGER_PROJECT_REF=proj_your_project_ref

# One secret key per environment; the tr_dev_ / tr_prod_ prefix decides where SDK-triggered runs land.
TRIGGER_SECRET_KEY_DEV=
TRIGGER_SECRET_KEY_PROD=

# --- Claude (sentiment classification) ----------------------------------------
# Classifies each matched email's tone (src/lib/sentiment.ts); missing key degrades to "neutral". Key: https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional; defaults in code to claude-opus-4-8. Set claude-haiku-4-5 to trade quality for cost.
ANTHROPIC_MODEL=

# --- Agent config (poll-inbox reads these per environment) -------------------
# Substring/address matched against each email's "from"; blank = keep all (e.g. "no-reply@ouraring.com").
WATCH_SENDER=

# 44-char Google Sheet id (from the sheet URL) that matching emails get appended to, one row per match.
TARGET_SHEET_ID=
