# Copy to .env and fill in. Never commit .env (it's gitignored).

# --- Composio (Gmail auth + tooling) -----------------------------------------
# All Gmail access goes through Composio: it hosts the OAuth consent flow, stores
# and refreshes each client's tokens, and exposes Gmail as callable tools.
# Get your key from https://app.composio.dev (Settings → API Keys).
COMPOSIO_API_KEY=

# Optional. Pin the Gmail auth config id so cold starts skip the find-or-create
# lookup. Leave blank the first time — the app auto-provisions one and logs its
# id, which you can paste back here.
COMPOSIO_GMAIL_AUTH_CONFIG_ID=

# Optional. Same as above but for the Google Sheets auth config (used by the
# connect-client-sheets step). Leave blank the first time; auto-provisioned.
COMPOSIO_GOOGLESHEETS_AUTH_CONFIG_ID=

# Optional. Pinned Gmail toolkit version. Manual tool execution (tools.execute)
# rejects "latest" and requires an explicit version. Defaults in code to a known
# good version; override here to bump. See toolkit.availableVersions via the API.
COMPOSIO_GMAIL_TOOLKIT_VERSION=

# Optional. Pinned Google Sheets toolkit version — same rule as Gmail above
# (tools.execute rejects "latest"). Versions are per-toolkit, so this is pinned
# separately. The client must also have linked the *googlesheets* toolkit (not
# just Gmail) under their userId for the sheet write to succeed.
COMPOSIO_GOOGLESHEETS_TOOLKIT_VERSION=

# --- Azure OpenAI (sentiment classification) ---------------------------------
# The poll task classifies each matched email's tone with one LLM call (see
# src/lib/sentiment.ts). For deployed environments, set these in the
# Trigger.dev dashboard. Missing key/endpoint degrades gracefully: rows still
# land in the sheet with sentiment "neutral".
AZURE_OPENAI_API_KEY=

# Your Azure OpenAI resource's OpenAI-compatible v1 endpoint:
# https://<resource>.openai.azure.com/openai/v1
AZURE_OPENAI_ENDPOINT=

# Optional; defaults in code to gpt-4.1.
AZURE_OPENAI_DEPLOYMENT=

# --- Trigger.dev -------------------------------------------------------------
# Your project ref from the trigger.dev dashboard (Project settings). Used by
# trigger.config.ts for `trigger.dev dev` and `deploy`.
TRIGGER_PROJECT_REF=proj_your_project_ref

# One secret key per environment. The prefix (tr_dev_ / tr_prod_) decides which
# environment a run lands in when you trigger tasks via the SDK. Dashboard → API
# keys. (Running tasks from the dashboard doesn't need these.)
TRIGGER_SECRET_KEY_DEV=
TRIGGER_SECRET_KEY_PROD=

# --- Agent config (poll-inbox reads these per environment) -------------------
# The roster is NOT stored here — it's the set of Trigger.dev schedules created
# by onboard-client (one per user, tagged externalId=userId). These two vars are
# just the agent's behavior config; set them in the Trigger.dev dashboard for the
# deployed environment (they're read via process.env in the poll-inbox task).

# Substring/address the "from" of each email is matched against. Blank = keep all.
# e.g. "no-reply@ouraring.com"
WATCH_SENDER=

# Google Sheet id that matching emails get appended to (one row per match:
# date, from, subject, snippet, messageId, threadId, sentiment). It's the
# 44-char id from the sheet URL. Rows are appended below "Sheet1"'s existing
# data.
TARGET_SHEET_ID=
